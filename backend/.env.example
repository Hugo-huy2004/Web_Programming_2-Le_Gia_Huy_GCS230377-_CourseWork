PORT=4000
NODE_ENV=development

# Required
MONGODB_URI=mongodb://127.0.0.1:27017/hwj
JWT_SECRET=replace_with_strong_secret
ADMIN_API_KEY=replace_with_admin_api_key

# Frontend allowed origins (comma-separated)
CLIENT_ORIGIN=http://localhost:5173,http://localhost:5174

# Google OAuth verification
GOOGLE_CLIENT_ID=

# Mail (fallback values are applied if left empty)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@hwj.local

# API rate limiting
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=8

# Optional cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# PayPal verification
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
